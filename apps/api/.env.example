# ---------------------------------------------------------------------------
# LeadOS API environment (BRD §19.1 — never commit the real .env)
# ---------------------------------------------------------------------------

# Server
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=debug            # debug | info | warn | error (default: info in prod)

# Database (BRD §15.1 Neon PostgreSQL in production).
# Local dev default uses SQLite so it runs with zero external services.
# For Postgres/Neon (FREE tier), use the POOLED connection string and a small
# connection_limit so the free pool isn't exhausted:
#   DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.neon.tech/db?sslmode=require&connection_limit=5&pool_timeout=20"
# and change datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Queue / Cron (BRD §14) — used from Module 9/10 onward
REDIS_URL=""                 # e.g. Upstash rediss://... (empty = in-process queue)
CRON_SECRET="change-me-cron-secret"

# Feature flags (BRD §13.1, §11.3)
FLAG_AI_SCORING_ENABLED=false

# AI provider (BRD §13.2) — leave AI_PROVIDER blank to use rule-based fallbacks.
# Set FLAG_AI_SCORING_ENABLED=true AND one provider+key to enable real AI.
AI_PROVIDER=""              # openai | groq | gemini
AI_MODEL=""                # optional override, else a sensible default per provider
OPENAI_API_KEY=""
GROQ_API_KEY=""
GEMINI_API_KEY=""

# Demo seed guardrails (BRD §18)
ALLOW_DEMO_SEED=false

# Notifications / email (BRD §14.4, §15.2) — free default is console/no-op.
EMAIL_ENABLED=false
SMTP_URL=""
FROM_EMAIL="no-reply@leados.example"

# Google OAuth (BRD §15.2) — shared by Calendar and SSO login. Blank = disabled.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/v1/calendar/callback"
# SSO login uses a separate redirect URI:
GOOGLE_LOGIN_REDIRECT_URI="http://localhost:4000/api/v1/sso/google/callback"

# Billing / Stripe (BRD §15.2) — blank = mock mode (plans still work locally)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
ENFORCE_PLAN_LIMITS=true

# Meta / social (BRD §16) — leave blank; real sends & webhooks disabled without
# these. META_APP_SECRET is also used to verify data-deletion/deauthorize
# signed_requests required for Meta App Review.
META_APP_SECRET=""
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
META_WEBHOOK_VERIFY_TOKEN=""
