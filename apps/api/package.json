{
  "name": "@leados/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "worker": "tsx watch src/worker.ts",
    "worker:start": "node dist/src/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:walkthrough": "tsx scripts/demo-walkthrough.ts",
    "load-test": "tsx scripts/load-test.ts",
    "make:superadmin": "tsx scripts/make-superadmin.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@leados/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2",
    "tsx": "^4.10.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  }
}
